{
  "name": "situationship",
  "version": "0.2.0",
  "description": "Run OpenAI/Codex models alongside Claude models in Claude Code",
  "type": "module",
  "bin": {
    "situationship": "bin/situationship.js"
  },
  "scripts": {
    "check": "node --check lib/router.js && node --check lib/session-log.js && node --check lib/system-prompt.js && node --check bin/situationship.js",
    "test": "node --test",
    "prepublishOnly": "npm run check && npm test"
  },
  "files": [
    "bin",
    "lib",
    "docs",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "chatgpt",
    "anthropic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robinebers/situationship.git"
  },
  "bugs": {
    "url": "https://github.com/robinebers/situationship/issues"
  },
  "homepage": "https://github.com/robinebers/situationship#readme",
  "dependencies": {
    "rotating-file-stream": "^3.2.9"
  }
}
